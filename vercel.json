{
  "version": 2,
  "builds": [
    {
      "src": "api/tts.js",
      "use": "@vercel/node"
    },
    {
      "src": "**/*",
      "use": "@vercel/static",
      "config": {
        "exclude": ["api/**", ".vercelignore", "vercel.json", ".git/**"]
      }
    }
  ],
  "routes": [
    {
      "src": "/api/tts",
      "dest": "/api/tts.js"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}
